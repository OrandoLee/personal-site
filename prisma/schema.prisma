generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyUpdate {
  id          String   @id @default(cuid())
  title       String
  type        String
  date        DateTime
  description String
  cover       String?
  link        String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, date])
  @@index([type, date])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  date      DateTime
  category  String
  tags      String   @default("[]")
  summary   String
  cover     String?
  content   String
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  collectionItems ArticleCollectionItem[]

  @@index([published, featured, date])
  @@index([published, date])
  @@index([category, date])
}

model ArticleCollection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  cover       String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       ArticleCollectionItem[]

  @@index([published, featured, sortOrder])
  @@index([published, updatedAt])
}

model ArticleCollectionItem {
  id           String            @id @default(cuid())
  collectionId String
  articleId    String
  sortOrder    Int               @default(100)
  createdAt    DateTime          @default(now())
  collection   ArticleCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article      Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([collectionId, articleId])
  @@index([collectionId, sortOrder])
  @@index([articleId])
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String
  src         String
  images      String   @default("[]")
  thumbnail   String?
  date        DateTime
  description String
  tags        String   @default("[]")
  category    String
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, featured, date])
  @@index([published, date])
  @@index([category, date])
  @@index([type, date])
}

model LabProject {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String?
  categoryKey String
  category    String
  status      String
  coverImage  String?
  openMode    String
  embedUrl    String?
  externalUrl String?
  internalPath String?
  sortOrder   Int      @default(100)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
  @@index([categoryKey, isPublished])
  @@index([updatedAt])
}

model OraskMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  source    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
  @@index([email, createdAt])
}
